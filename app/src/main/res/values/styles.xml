<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="OtpEditTextStyle" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/bg_otp_box</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/gray_dark</item>
        <item name="android:textColorHint">@color/gray_light</item>
        <item name="android:inputType">number</item>
        <item name="android:padding">12dp</item>
        <item name="android:minHeight">60dp</item>
        <item name="android:maxHeight">60dp</item>
        <item name="android:importantForAutofill">no</item>
    </style>
    
    <style name="ToolbarTitleStyle">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/primary</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>
</resources>
