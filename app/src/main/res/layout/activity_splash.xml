<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_gradient">

    <!-- Animated Wave Background -->
    <View
        android:id="@+id/wave_background"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/wave_background"
        android:alpha="0.15" />

    <!-- Floating Circles Animation -->
    <View
        android:id="@+id/circle1"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="64dp"
        android:background="@drawable/circle_animation"
        android:alpha="0.3" />

    <View
        android:id="@+id/circle2"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="-40dp"
        android:layout_marginTop="120dp"
        android:background="@drawable/circle_animation"
        android:alpha="0.2" />

    <View
        android:id="@+id/circle3"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginEnd="48dp"
        android:layout_marginTop="320dp"
        android:layout_alignParentEnd="true"
        android:background="@drawable/circle_animation"
        android:alpha="0.25" />

    <!-- Container chính với hiệu ứng nâng cao -->
    <LinearLayout
        android:id="@+id/container_main"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center"
        android:alpha="0"
        android:animateLayoutChanges="true">

        <!-- Card container cho logo -->
        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="40dp"
            app:cardElevation="16dp"
            app:cardBackgroundColor="@color/white_transparent_30"
            android:padding="16dp">

            <!-- Logo quả cam + ống kính với glow effect -->
            <ImageView
                android:id="@+id/iv_logo"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:src="@drawable/logo_chiacam"
                android:contentDescription="@string/app_name"
                android:alpha="0.95" />

        </androidx.cardview.widget.CardView>

        <!-- Tên app với shadow -->
        <TextView
            android:id="@+id/tv_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chia Cam"
            android:textSize="44sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginTop="20dp"
            android:letterSpacing="0.03"
            android:fontFamily="sans-serif-black"
            android:shadowColor="@color/black_transparent_50"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="4" />

        <!-- Slogan with typing animation -->
        <TextView
            android:id="@+id/tv_slogan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="15sp"
            android:textColor="@color/white"
            android:alpha="0.9"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-medium" />

        <!-- Decorative line -->
        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:layout_marginTop="16dp"
            android:background="@color/white"
            android:alpha="0.5" />

    </LinearLayout>

    <!-- Loading indicator với animation -->
    <ProgressBar
        android:id="@+id/progress_bar"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="56dp"
        android:indeterminateTint="@color/white"
        android:visibility="gone" />

    <!-- Loading text -->
    <TextView
        android:id="@+id/tv_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/progress_bar"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="8dp"
        android:text="Đang khởi tạo..."
        android:textSize="11sp"
        android:textColor="@color/white"
        android:alpha="0.6"
        android:visibility="gone" />

    <!-- Version text với effect -->
    <TextView
        android:id="@+id/tv_version"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_marginBottom="16dp"
        android:layout_marginStart="16dp"
        android:text="v1.0.0"
        android:textSize="10sp"
        android:textColor="@color/white"
        android:alpha="0.5" />

    <!-- Copyright -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="16dp"
        android:text="© 2024 Chia Cam"
        android:textSize="9sp"
        android:textColor="@color/white"
        android:alpha="0.35" />

</RelativeLayout>