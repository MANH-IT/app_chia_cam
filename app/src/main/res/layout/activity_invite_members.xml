<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_gray">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        app:title="@string/invite_title"
        app:titleTextColor="@color/gray_dark"
        app:navigationIcon="@drawable/ic_close"
        app:navigationIconTint="@color/gray_dark" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Invite Link Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/invite_link_title"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/gray_dark"
                        android:layout_marginBottom="12dp" />

                    <!-- Link Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_link"
                        android:padding="12dp"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/tv_invite_link"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="chia.cam/join/ABC123"
                            android:textSize="12sp"
                            android:textColor="@color/gray_dark"
                            android:maxLines="1"
                            android:ellipsize="middle" />

                        <ImageView
                            android:id="@+id/iv_copy_link"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_copy"
                            app:tint="@color/primary"
                            android:layout_marginStart="8dp"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                    <!-- Share Via Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/invite_share_via"
                        android:textSize="13sp"
                        android:textColor="@color/gray_medium"
                        android:layout_marginBottom="12dp" />

                    <!-- Share Buttons Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <!-- Zalo -->
                        <LinearLayout
                            android:id="@+id/ll_share_zalo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="8dp">

                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_circular_dark"
                                android:backgroundTint="#0068FF">

                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_zalo_share" />

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Zalo"
                                android:textSize="11sp"
                                android:textColor="@color/gray_medium"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                        <!-- Messenger -->
                        <LinearLayout
                            android:id="@+id/ll_share_messenger"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="8dp">

                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_circular_dark"
                                android:backgroundTint="#0084FF">

                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_messenger_share" />

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Messenger"
                                android:textSize="11sp"
                                android:textColor="@color/gray_medium"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                        <!-- SMS -->
                        <LinearLayout
                            android:id="@+id/ll_share_sms"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="8dp">

                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_circular_dark"
                                android:backgroundTint="#4CAF50">

                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_sms_share" />

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SMS"
                                android:textSize="11sp"
                                android:textColor="@color/gray_medium"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                        <!-- Telegram -->
                        <LinearLayout
                            android:id="@+id/ll_share_telegram"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="8dp">

                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_circular_dark"
                                android:backgroundTint="#229ED9">

                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_telegram_share" />

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Telegram"
                                android:textSize="11sp"
                                android:textColor="@color/gray_medium"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Contacts Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/invite_contacts_title"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/gray_dark"
                        android:layout_marginBottom="12dp" />

                    <!-- Sync Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_sync_contacts"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/invite_sync_contacts"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        app:cornerRadius="24dp"
                        app:backgroundTint="@color/primary"
                        android:layout_marginBottom="16dp" />

                    <!-- Contacts List -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_contacts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                    <!-- Empty Contacts View -->
                    <TextView
                        android:id="@+id/tv_no_contacts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/invite_no_contacts"
                        android:textSize="14sp"
                        android:textColor="@color/gray_medium"
                        android:gravity="center"
                        android:padding="24dp"
                        android:visibility="gone" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Manual Phone Input Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/invite_phone_title"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/gray_dark"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxStrokeColor="@color/primary"
                            app:boxStrokeWidth="1.5dp"
                            android:layout_marginEnd="12dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_phone_number"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/invite_phone_hint"
                                android:inputType="phone"
                                android:maxLines="1" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_invite_phone"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:text="@string/invite_button"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            app:cornerRadius="24dp"
                            app:backgroundTint="@color/primary" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
