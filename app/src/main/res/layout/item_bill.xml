<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_bill"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="10dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Image Container -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/iv_product_image"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_placeholder"
                tools:src="@drawable/ic_placeholder" />

            <!-- Overlays for premium feel -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_gravity="top"
                android:background="@drawable/gradient_scrim_top" />

            <!-- Time Badge -->
            <TextView
                android:id="@+id/tv_time_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="16dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="2 giờ trước"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_time_badge_premium" />

            <!-- Split Type Badge -->
            <TextView
                android:id="@+id/tv_split_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="16dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/split_household"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_split_badge_premium" />

        </FrameLayout>

        <!-- Product Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Product Name -->
                <TextView
                    android:id="@+id/tv_product_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/tv_amount"
                    android:layout_marginEnd="8dp"
                    android:text="Mì tôm"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- Amount -->
                <TextView
                    android:id="@+id/tv_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="35.000đ"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />

            </RelativeLayout>

            <!-- Actor Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_person"
                    app:tint="@color/gray_medium"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tv_actor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mạnh mua • chia 4 người"
                    android:textSize="13sp"
                    android:textColor="@color/gray_medium" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/gray_lighter"
                android:layout_marginVertical="16dp" />

            <!-- Reactions Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:weightSum="4">

                <!-- Reaction 1: 😂 -->
                <LinearLayout
                    android:id="@+id/ll_reaction_1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_reaction_button_premium"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="😂"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/tv_reaction_1_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/gray_medium"
                        android:layout_marginStart="6dp" />

                </LinearLayout>

                <!-- Reaction 2: 😭 -->
                <LinearLayout
                    android:id="@+id/ll_reaction_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_reaction_button_premium"
                    android:layout_marginHorizontal="3dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="😭"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/tv_reaction_2_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/gray_medium"
                        android:layout_marginStart="6dp" />

                </LinearLayout>

                <!-- Reaction 3: 👍 -->
                <LinearLayout
                    android:id="@+id/ll_reaction_3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_reaction_button_premium"
                    android:layout_marginHorizontal="3dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👍"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/tv_reaction_3_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/gray_medium"
                        android:layout_marginStart="6dp" />

                </LinearLayout>

                <!-- Reaction 4: ❤️ -->
                <LinearLayout
                    android:id="@+id/ll_reaction_4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_reaction_button_premium"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="❤️"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/tv_reaction_4_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/gray_medium"
                        android:layout_marginStart="6dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
