<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_gray">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        app:navigationIcon="@drawable/ic_close"
        app:navigationIconTint="@color/gray_dark" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- Loading Progress -->
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <!-- Content Container -->
            <LinearLayout
                android:id="@+id/content_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:visibility="visible">

                <!-- Group Avatar -->
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_group_avatar"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_default_group_avatar"
                    app:civ_border_width="3dp"
                    app:civ_border_color="@color/primary" />

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/join_group_title"
                    android:textSize="16sp"
                    android:textColor="@color/gray_medium"
                    android:layout_marginTop="16dp" />

                <!-- Group Name -->
                <TextView
                    android:id="@+id/tv_group_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhà mình"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:layout_marginTop="4dp" />

                <!-- Member Count -->
                <TextView
                    android:id="@+id/tv_member_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4 thành viên"
                    android:textSize="14sp"
                    android:textColor="@color/gray_medium"
                    android:layout_marginTop="8dp" />

                <!-- Inviter Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    android:layout_marginTop="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <!-- Inviter Avatar -->
                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/iv_inviter_avatar"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_default_avatar"
                            app:civ_border_width="1dp"
                            app:civ_border_color="@color/gray_light" />

                        <!-- Inviter Info -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:id="@+id/tv_inviter_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mạnh Nguyễn"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/gray_dark" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/join_group_invited_by"
                                android:textSize="12sp"
                                android:textColor="@color/gray_medium" />

                        </LinearLayout>

                        <!-- Check Icon -->
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_check_circle"
                            app:tint="@color/success" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Description Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    android:layout_marginTop="16dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/join_group_description_title"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/gray_dark"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tv_description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Nhóm chi tiêu gia đình - cùng nhau quản lý chi phí ăn uống, sinh hoạt hàng ngày."
                            android:textSize="14sp"
                            android:textColor="@color/gray_medium"
                            android:lineSpacingExtra="4dp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="32dp"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_cancel"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="@string/join_group_btn_cancel"
                        android:textSize="14sp"
                        app:cornerRadius="24dp"
                        app:strokeColor="@color/gray_light"
                        app:strokeWidth="1dp"
                        android:textColor="@color/gray_dark"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_join"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="@string/join_group_btn_join"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        app:cornerRadius="24dp"
                        app:backgroundTint="@color/primary"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Error Container -->
            <LinearLayout
                android:id="@+id/error_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_error_outline"
                    app:tint="@color/warning"
                    android:layout_marginTop="32dp" />

                <TextView
                    android:id="@+id/tv_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/join_group_invalid"
                    android:textSize="16sp"
                    android:textColor="@color/gray_dark"
                    android:gravity="center"
                    android:layout_marginTop="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_retry"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="@string/join_group_retry"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    app:cornerRadius="24dp"
                    app:backgroundTint="@color/primary"
                    android:layout_marginTop="24dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
