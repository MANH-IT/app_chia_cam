<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Search Bar -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/add_member_search_hint"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:endIconMode="clear_text"
        android:layout_margin="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Contacts Section Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/add_member_contacts_title"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/gray_dark"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="8dp" />

    <!-- Contacts RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_contacts"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:nestedScrollingEnabled="true" />

    <!-- Empty Contacts View -->
    <TextView
        android:id="@+id/tv_empty_contacts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/add_member_empty"
        android:textSize="14sp"
        android:textColor="@color/gray_medium"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone" />

    <!-- Permission Required View -->
    <LinearLayout
        android:id="@+id/ll_permission_required"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_member_contact_permission"
            android:textSize="14sp"
            android:textColor="@color/gray_medium"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_request_permission"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_member_request_permission"
            app:cornerRadius="20dp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gray_light"
        android:layout_marginVertical="12dp" />

    <!-- Selected Count -->
    <TextView
        android:id="@+id/tv_selected_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/add_member_selected_count"
        android:textSize="12sp"
        android:textColor="@color/gray_medium"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="12dp" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="@string/cancel"
            android:textSize="14sp"
            app:cornerRadius="22dp"
            app:strokeColor="@color/gray_light"
            app:strokeWidth="1dp"
            app:backgroundTint="@color/white"
            android:textColor="@color/gray_dark"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="@string/add"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:cornerRadius="22dp"
            app:backgroundTint="@color/primary"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>