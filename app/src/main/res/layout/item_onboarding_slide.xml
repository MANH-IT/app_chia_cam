<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="@drawable/bg_onboarding_gradient">

        <!-- Icon Container với background tròn -->
        <androidx.cardview.widget.CardView
            android:layout_width="140dp"
            android:layout_height="140dp"
            app:cardCornerRadius="70dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="@color/white"
            android:layout_marginTop="40dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <!-- Icon (Emoji) -->
                <TextView
                    android:id="@+id/tv_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="72sp"
                    tools:text="📸" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Decorative line -->
        <View
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:layout_marginTop="32dp"
            android:background="@color/primary"
            android:alpha="0.6" />

        <!-- Tiêu đề -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/gray_dark"
            android:layout_marginTop="24dp"
            android:gravity="center"
            tools:text="Chụp là chia" />

        <!-- Mô tả chính -->
        <TextView
            android:id="@+id/tv_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/gray_medium"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:lineSpacingExtra="6dp"
            tools:text="Chụp ảnh đồ mua / hóa đơn\nxong ngay, không cần gõ" />

        <!-- Sub description -->
        <TextView
            android:id="@+id/tv_sub_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/primary"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/bg_sub_description"
            tools:text="Quét thông minh AI" />

    </LinearLayout>

</ScrollView>
