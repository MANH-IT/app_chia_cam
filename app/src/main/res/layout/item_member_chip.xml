<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.chip.Chip xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/chip_member"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:chipBackgroundColor="@color/gray_lighter"
    app:chipStrokeColor="@color/gray_light"
    app:chipStrokeWidth="0.5dp"
    android:textColor="@color/gray_dark"
    app:chipIcon="@drawable/ic_person"
    app:chipIconTint="@color/primary"
    app:closeIconTint="@color/gray_medium"
    app:closeIconVisible="true" />
