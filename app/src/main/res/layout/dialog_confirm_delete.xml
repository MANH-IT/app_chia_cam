<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white">

    <!-- Warning Icon -->
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/iv_warning"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_warning" />

    </FrameLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Xóa bill?"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/gray_dark"
        android:layout_gravity="center"
        android:layout_marginBottom="12dp" />

    <!-- Message -->
    <TextView
        android:id="@+id/tv_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bill này sẽ bị xóa vĩnh viễn khỏi tất cả thành viên.\n\nCông nợ sẽ được cập nhật lại."
        android:textSize="14sp"
        android:textColor="@color/gray_medium"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="16dp" />

    <!-- Warning Impact (for group deletion) -->
    <TextView
        android:id="@+id/tv_warning_impact"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚠️ Hành động này ảnh hưởng đến 4 thành viên"
        android:textSize="12sp"
        android:textColor="@color/warning"
        android:gravity="center"
        android:background="@color/warning_light"
        android:padding="12dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone" />

    <!-- Extra Confirm Input (for group deletion) -->
    <LinearLayout
        android:id="@+id/ll_extra_confirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/confirm_delete_group_extra_confirm"
            android:textSize="12sp"
            android:textColor="@color/gray_medium"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="@color/error"
            app:boxStrokeWidth="1.5dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_confirm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="XÓA"
                android:inputType="text"
                android:maxLines="1"
                android:gravity="center" />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/confirm_delete_cancel"
            android:textSize="14sp"
            android:textColor="@color/gray_dark"
            app:cornerRadius="24dp"
            app:strokeColor="@color/gray_light"
            app:strokeWidth="1dp"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/confirm_delete_confirm"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:cornerRadius="24dp"
            app:backgroundTint="@color/error"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>
